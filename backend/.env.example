# TALBI'FLUID — Configuration d'environnement
# Copier ce fichier en .env et remplir les valeurs pour votre environnement
# NE JAMAIS COMMITER .env (contient des secrets)

# ========== ADMIN CREDENTIALS ==========
# Générer le hash bcrypt avec: node -e "require('bcrypt').hash('votre-mot-de-passe', 10, (err, hash) => console.log(hash))"
ADMIN_USER=admin
ADMIN_PASS_HASH=$2b$10$... # Remplacer par le hash bcrypt réel

# ========== JWT CONFIGURATION ==========
# Générer une clé secrète sécurisée (par exemple avec: openssl rand -hex 32)
JWT_SECRET=your-very-secure-secret-key-change-in-production

# ========== SMTP CONFIGURATION ==========
# Gmail : activer "App passwords" (2FA requis)
# Autres : utiliser les identifiants SMTP du fournisseur
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ========== EMAIL ADMIN ==========
# Email où les demandes de contact sont envoyées
ADMIN_EMAIL=admin@talbifluid.fr

# ========== OPTIONNEL ==========
PORT=3000
NODE_ENV=production
